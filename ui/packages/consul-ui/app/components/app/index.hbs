{{#let (hash main='hds-main' Notification=(component 'app/notification')) as |exported|}}

  <div class='app' ...attributes>
    <Hds::AppFrame
      @hasHeader={{false}}
      @hasFooter={{false}}
      @hasModals={{true}}
      class='app-shell'
    as |Frame|>
      <Frame.Sidebar class='app-shell__sidebar'>
        {{yield exported to='sideNav'}}
      </Frame.Sidebar>
      <Frame.Modals>
        <ModalLayer />
      </Frame.Modals>
      <Frame.Main class='app-shell__main'>
        <div class='notifications'>
          {{yield exported to='notifications'}}
          <PortalTarget @name='app-notifications' @multiple={{true}} />
        </div>
        {{yield exported to='main'}}
      </Frame.Main>
    </Hds::AppFrame>
  </div>

{{/let}}