{{#let (hash labelledby=(dom-guid)) as |aria|}}
  {{#let (hash open=(action 'open') close=(action 'close') opened=this.isOpen aria=aria) as |api|}}
  <Portal @target='modal'>
    {{yield api}}
    <div
      class='modal-dialog'
      aria-hidden='true'
      ...attributes
      {{did-insert (action 'connect')}}
      {{will-destroy (action 'disconnect')}}
    >
      <div tabindex='-1' data-a11y-dialog-hide></div>
      <div class='modal-dialog-modal' role='dialog' aria-label={{@aria.label}}>
        <div role='document'>
          <header class='modal-dialog-header'>
            <Hds::Button
              data-a11y-dialog-hide
              @text='Close dialog'
              @color='secondary'
              @icon='x'
              @size='small'
              @isIconOnly={{true}}
            />
            {{#if (has-block 'header')}}
              {{yield api to='header'}}
            {{else}}
              {{yield api}}
            {{/if}}
          </header>
          <div class='modal-dialog-body'>
            {{#if (has-block 'body')}}
              {{yield api to='body'}}
            {{else}}
              {{yield api}}
            {{/if}}
          </div>
          <div class='modal-dialog-footer'>
            {{#if (has-block 'actions')}}
              {{yield (action 'close') to='actions'}}
            {{else}}
              {{yield api}}
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </Portal>
  {{/let}}
{{/let}}