{{yield}}
<StateChart @src={{this.chart}} as |State Guard Action dispatch state|>
  <Ref @target={{this}} @name="dispatch" @value={{dispatch}} />
  <Guard @name="loaded" @cond={{action "isLoaded"}} />


{{#let (hash
  data=this.data
  error=this.error
  invalidate=this.invalidate
  dispatchError=(queue (action (mut this.error) value="error.errors.firstObject") (action dispatch "ERROR"))
) as |api|}}

    {{#if (has-block "data")}}
      {{yield api to="data"}}
    {{else}}
      {{! if we didn't specify any data}}
      {{#if (not @items)}}
        {{! try and load the data if we aren't in an error state}}
        <State @notMatches={{array "error" "disconnected"}}>
          {{! but only if we only asked for a single load and we are in loading state}}
          {{#if (and @src (or (not @once) (state-matches state "loading")))}}
            <DataSource
              @open={{@open}}
              @src={{@src}}
              @onchange={{queue (action "change" value="data") (action dispatch "SUCCESS")}}
              @onerror={{api.dispatchError}}
            as |source|>
              {{did-insert-helper (set this 'invalidate' source.invalidate)}}
            </DataSource>
          {{/if}}
        </State>
      {{/if}}
    {{/if}}

  <State @matches="loading">
    {{#if (has-block "loading")}}
      {{yield api to="loading"}}
    {{else}}
      <Consul::Loader />
    {{/if}}
  </State>

  <State @matches="error">
    {{#if (has-block "error")}}
      {{yield api to="error"}}
    {{else}}
      <ErrorState @error={{this.error}} />
    {{/if}}
  </State>

  <State @matches={{array "idle" "disconnected"}}>

    <State @matches="disconnected">
      {{#if (not (eq this.error.status '401'))}}
        {{#if (has-block "disconnected")}}
            {{yield api (action dispatch "RESET") to="disconnected"}}
        {{else}}
          <Hds::Toast @color='warning'
            {{notification
              sticky=true
            }} as |T|>
            <T.Title>Warning!</T.Title>
            <T.Description>An error was returned whilst loading this data, refresh to try again.</T.Description>
          </Hds::Toast>
        {{/if}}
      {{/if}}
    </State>
    {{#if (eq this.error.status "403")}}
      {{#if (has-block "error")}}
        {{yield api to="error"}}
      {{else}}
        <ErrorState @error={{this.error}} />
      {{/if}}
    {{else}}
      {{yield api to="loaded"}}
    {{/if}}

  </State>

{{/let}}
  {{did-update-helper (fn dispatch "LOAD") src=@src}}
</StateChart>
