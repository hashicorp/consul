<div class="consul-peer-list" ...attributes>
  <Consul::DataTable
    @items={{@items}}
    @columns={{this.columns}}
    @ariaLabel="Peers"
    @initialSortBy="state"
    @initialSortOrder="asc"
  >
    <:row as |item B|>
      {{! ---- Peer name ---- }}
      <B.Td>
        {{#if (can "delete peer" item=item)}}
          <a
            data-test-peer={{item.Name}}
            href={{href-to "dc.peers.show" item.Name}}
            {{hds-tooltip item.Name options=(detached-tooltip-options)}}
          >{{item.Name}}</a>
        {{else}}
          <p
            data-test-peer={{item.Name}}
            {{hds-tooltip item.Name options=(detached-tooltip-options)}}
          >{{item.Name}}</p>
        {{/if}}
      </B.Td>

      {{! ---- Status ---- }}
      <B.Td>
        <Peerings::Badge @peering={{item}} />
      </B.Td>

      {{! ---- Imported services count ---- }}
      <B.Td>
        <span
          data-test-imported-count
          {{hds-tooltip
            (t "routes.dc.peers.index.detail.imported.tooltip" name=item.Name)
            options=(detached-tooltip-options)
          }}
        >{{format-number item.ImportedServiceCount}}</span>
      </B.Td>

      {{! ---- Exported services count ---- }}
      <B.Td>
        <span
          data-test-exported-count
          {{hds-tooltip
            (t "routes.dc.peers.index.detail.exported.tooltip" name=item.Name)
            options=(detached-tooltip-options)
          }}
        >{{format-number item.ExportedServiceCount}}</span>
      </B.Td>

      {{! ---- Actions ---- }}
      <B.Td @align="right">
        {{#if (can "delete peer" item=item)}}
          <Hds::Dropdown @listPosition="bottom-right" class="consul-peer-list__actions" as |dd|>
            <dd.ToggleIcon
              @icon="more-horizontal"
              @text="Open actions menu"
              @hasChevron={{false}}
              @size="small"
              data-test-actions-menu
            />
            {{#if (and (can "write peer" item=item) item.isDialer)}}
              <dd.Interactive data-test-regenerate {{on "click" (fn @onedit item)}}>
                Regenerate token
              </dd.Interactive>
            {{/if}}
            <dd.Interactive @route="dc.peers.show" @model={{item.Name}} data-test-view>
              View
            </dd.Interactive>
            <dd.Separator />
            <dd.Interactive
              @color="critical"
              @icon="trash"
              data-test-delete
              {{on "click" (fn this.confirmDelete item)}}
            >
              Delete
            </dd.Interactive>
          </Hds::Dropdown>
        {{/if}}
      </B.Td>
    </:row>
  </Consul::DataTable>

  {{#if this.itemToDelete}}
    <Hds::Modal id="confirm-modal" @color="warning" @onClose={{this.cancelDelete}} as |M|>
      <M.Header @icon="alert-triangle">Confirm delete</M.Header>
      <M.Body>
        <p>Are you sure you want to delete this peer?</p>
      </M.Body>
      <M.Footer as |F|>
        <Hds::ButtonSet>
          <Hds::Button
            @text="Delete"
            @color="critical"
            data-test-id="confirm-action"
            {{on "click" this.invokeDelete}}
          />
          <Hds::Button @text="Cancel" @color="secondary" {{on "click" F.close}} />
        </Hds::ButtonSet>
      </M.Footer>
    </Hds::Modal>
  {{/if}}
</div>
