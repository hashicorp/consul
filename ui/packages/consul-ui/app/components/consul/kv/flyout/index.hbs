{{#if @isCreate}}
  {{page-title "New Key / Value"}}
{{else}}
  {{page-title "Edit Key / Value"}}
{{/if}}

{{! Self-contained: fetches the KV entry itself (or a blank one when creating), }}
{{! so the caller only needs to know which key is selected. }}
<DataLoader
  @src={{uri '/${partition}/${nspace}/${dc}/kv/${key}'
    (hash
      partition=@partition
      nspace=@nspace
      dc=@dc
      key=(if @isCreate '' @selected)
    )
  }}>
  <:error as |loader|>
    <Hds::Flyout @size="large" @onClose={{fn @onsubmit undefined}} as |F|>
      <F.Header @icon="key">Error</F.Header>
      <F.Body>
        <ErrorState @error={{loader.error}} />
      </F.Body>
    </Hds::Flyout>
  </:error>

  <:loaded as |loader|>
{{#let loader.data as |item|}}
    <DataForm
      @dc={{@dc}}
      @nspace={{@nspace}}
      @partition={{@partition}}
      @type='kv'
      @label='key'
      @item={{item}}
      @onchange={{action this.change}}
      @onsubmit={{action @onsubmit}}
    >
      <:content as |api|>
        {{#let (cannot 'write kv' item=api.data) as |disabld|}}
          <Hds::Flyout @size="large" @onClose={{fn @onsubmit api.data}} as |F|>
            <F.Header @icon="key" data-test-kv-key={{item.Key}}>
              {{#if (and item.Key (not-eq item.Key @parent))}}
                {{left-trim item.Key @parent}}
              {{else}}
                New Key / Value
              {{/if}}
            </F.Header>

            <F.Body>
             <Hds::Layout::Flex class='consul-kv-flyout__body' @direction='column' @gap='24' as |Body|>
              <Body.Item>
              <form id={{this.formId}} onsubmit={{action api.submit}}>
                <fieldset {{disabled (or disabld api.disabled)}}>
                  {{#if api.isCreate}}
                    <label data-test-kv-key class='type-text{{if api.data.error.Key " has-error"}}'>
                      <span>Key or folder</span>
                      <input
                        type='text'
                        value={{left-trim api.data.Key @parent}}
                        name='additional'
                        oninput={{action api.change}}
                        placeholder='Key or folder'
                      />
                      <em>To create a folder, end a key with <code>/</code></em>
                    </label>
                  {{/if}}
                  {{#if (or (eq (left-trim api.data.Key @parent) '') (not-eq (last api.data.Key) '/'))}}
                    <Hds::Layout::Flex @direction='column' @gap='8' as |LF|>
                      {{! sits directly above the editor it switches }}
                      <LF.Item style='align-self: flex-end;'>
                        <Hds::Form::Toggle::Field
                          name='json'
                          checked={{if this.json 'checked'}}
                          {{on 'change' api.change}}
                          as |FT|
                        >
                          <FT.Label>Code</FT.Label>
                        </Hds::Form::Toggle::Field>
                      </LF.Item>
                      <label for='' class='type-text{{if api.data.error.Value " has-error"}}'>
                        {{#if this.json}}
                          {{#if (or disabld api.disabled)}}
                            <Hds::CodeBlock
                              @language='bash'
                              @value={{atob api.data.Value}}
                              @isStandalone={{false}}
                              @ariaLabel='value'
                              as |CB|
                            >
                              <CB.Title @tag='h2'>Value</CB.Title>
                            </Hds::CodeBlock>
                          {{else}}
                            <Hds::CodeEditor
                              class='consul-kv-flyout-value-editor'
                              @name='Value'
                              @readonly={{or disabld api.disabled}}
                              @value={{atob api.data.Value}}
                              @onInput={{action api.change 'value'}}
                              @language='yaml'
                              @ariaLabel='value'
                              @hasLineWrapping={{true}}
                              @hasCopyButton={{true}}
                              @isStandalone={{false}}
                              as |CE|
                            >
                              <CE.Title @tag='h2'>Value</CE.Title>
                            </Hds::CodeEditor>
                          {{/if}}
                        {{else}}
                          <span>Value</span>
                          <textarea
                            {{disabled (or disabld api.disabled)}}
                            name='value'
                            oninput={{action api.change}}
                          >{{atob api.data.Value}}</textarea>
                        {{/if}}
                      </label>
                    </Hds::Layout::Flex>
                  {{/if}}
                </fieldset>
              </form>
              </Body.Item>

              {{#if item.Session}}
                <Body.Item>
                  <Consul::LockSession::Notifications @type="kv" />
                </Body.Item>
                <Body.Item>
                  <DataSource
                    @src={{uri '/${partition}/${nspace}/${dc}/sessions/for-key/${id}'
                      (hash
                        partition=@partition
                        nspace=@nspace
                        dc=@dc
                        id=item.Session
                      )
                    }}
                    @onchange={{action this.setSession}}
                  />
                  {{! the heading lives in the card, next to Invalidate Session. }}
                  {{! invalidating the session closes the flyout (its @onsubmit), }}
                  {{! after the success toast has been raised by the DataWriter. }}
                  {{#if this.session.ID}}
                    <Consul::LockSession::Form
                      @item={{this.session}}
                      @ondelete={{@onsubmit}}
                    />
                  {{/if}}
                </Body.Item>
              {{/if}}
             </Hds::Layout::Flex>
            </F.Body>

            <F.Footer>
              <Hds::ButtonSet>
                {{#unless disabld}}
                  {{! a new key starts pristine and has nothing to save yet }}
                  <Hds::Button
                    @text='Save'
                    type='submit'
                    form={{this.formId}}
                    disabled={{or
                      (and api.isCreate api.data.isPristine)
                      api.data.isInvalid
                      api.disabled
                    }}
                  />
                {{/unless}}
                <Hds::Button
                  @text='Cancel'
                  @color='secondary'
                  type='reset'
                  form={{this.formId}}
                  disabled={{api.disabled}}
                  {{on 'click' (fn @onsubmit api.data)}}
                />
                {{#unless (or api.isCreate disabld)}}
                  <ConfirmationDialog @message='Are you sure you want to delete this key?'>
                    <:action as |confirm|>
                      <Hds::Button
                        @text='Delete'
                        @color='critical'
                        data-test-delete
                        disabled={{api.disabled}}
                        {{on 'click' (action confirm)}}
                      />
                    </:action>
                    <:dialog as |execute cancel message|>
                      <DeleteConfirmation
                        @message={{message}}
                        @execute={{queue execute api.delete}}
                        @cancel={{cancel}}
                      />
                    </:dialog>
                  </ConfirmationDialog>
                {{/unless}}
              </Hds::ButtonSet>
            </F.Footer>
          </Hds::Flyout>
        {{/let}}
      </:content>
    </DataForm>
{{/let}}
  </:loaded>
</DataLoader>
