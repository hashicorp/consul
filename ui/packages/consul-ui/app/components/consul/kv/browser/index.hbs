{{! Folders expand inline and keys open a flyout, so this never navigates away }}
{{! from the index route. `dc.kv.folder` survives only for deep-link entry into }}
{{! a nested key, and the back button below is its only way back to the root. }}
{{! The caller sets the document title, from route params rather than the }}
{{! fetched @parent, so it can't lag a transition behind the round-trip. }}

<AppView @showBreadcrumb={{not-eq @parent.Key '/'}}>
  <:breadcrumbs>
    <Breadcrumbs::BackButton @route="dc.kv" />
  </:breadcrumbs>
  <:header>
      <h1>
{{#if (eq @parent.Key '/')}}
        Key / Value
{{else}}
        {{take 1 (drop 1 (reverse (split @parent.Key '/')))}}
{{/if}}
      </h1>
      <label for="toolbar-toggle"></label>
  </:header>
  <:toolbar>
{{#if (gt @items.length 0) }}
    <Consul::Kv::Toolbar
      @search={{@search}}
      @onsearch={{@onsearch}}
      @sort={{@sort}}
      @filter={{@filters}}
    />
{{/if}}
  </:toolbar>
  <:actions>
{{#if (can 'create kvs')}}
  <Hds::Button
    @text='Create'
    data-test-create
    {{on 'click' (fn @onCreate (or @parent.Key '/'))}}
  />
{{/if}}
  </:actions>
  <:content>
    {{#let (refresh-route) as |refreshRoute|}}
    <DataWriter
      @sink={{uri '/${partition}/${nspace}/${dc}/kv/'
        (hash
          partition=@partition
          nspace=@nspace
          dc=@dc
        )
      }}
      @type="kv"
      @label="key"
      @ondelete={{refreshRoute}}>
      <:content as |writer|>
        <DataCollection
          @type="kv"
          @sort={{@sort.value}}
          @filters={{@filters}}
          @search={{@search}}
          @items={{@items}}
        as |collection|>
          <collection.Collection>
            <Consul::Kv::List
              @items={{collection.items}}
              @delete={{writer.delete}}
              @dc={{@dc}}
              @nspace={{@nspace}}
              @partition={{@partition}}
              @onSelect={{@onSelect}}
              @onCreate={{@onCreate}}
            />
          </collection.Collection>
          <collection.Empty>
            <EmptyState
              @login={{@login}}
            >
              <:header>
                <h2>
                  {{t 'routes.dc.kv.index.empty.header'
                    items=@items.length
                  }}
                </h2>
              </:header>
              <:body>
                {{t 'routes.dc.kv.index.empty.body'
                  items=@items.length
                  canUseACLs=(can "use acls")
                  htmlSafe=true
                }}
              </:body>
              <:actions>
                <li>
                  <Hds::Link::Standalone
                    @text='Documentation on K/V'
                    @href="{{env 'CONSUL_DOCS_URL'}}/automate/kv"
                    @icon='docs-link'
                    @iconPosition='trailing'
                    @size='small'
                  />
                </li>
                <li>
                  <Hds::Link::Standalone
                    @text='Take the tutorial'
                    @href="{{env 'CONSUL_DOCS_LEARN_URL'}}/consul/getting-started/kv"
                    @icon='learn-link'
                    @iconPosition='trailing'
                    @size='small'
                  />
                </li>
              </:actions>
            </EmptyState>
          </collection.Empty>
        </DataCollection>
      </:content>
    </DataWriter>
    {{/let}}
  </:content>
</AppView>
