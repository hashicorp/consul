<div class="consul-kv-list" ...attributes>
  <Consul::DataTable
    @items={{this.rows}}
    @columns={{this.columns}}
    @paginated={{false}}
    @ariaLabel="Key / Values"
  >
    <:row as |row B|>
      {{! ---- Key name (tree cell: indentation + chevron + icon + name) ---- }}
      <B.Td>
        <span class="consul-kv-list__cell" style={{row.indentStyle}}>
          {{#if row.isFolder}}
            <button
              type="button"
              class="consul-kv-list__toggle"
              aria-label={{if row.expanded "Collapse folder" "Expand folder"}}
              aria-expanded={{if row.expanded "true" "false"}}
              data-test-kv-toggle
              {{on "click" (fn this.toggle row.node)}}
            >
              <Hds::Icon @name={{if row.expanded "chevron-down" "chevron-right"}} @size="16" @isInline={{true}} />
            </button>
            <Hds::Icon class="consul-kv-list__icon" @name="folder" @size="16" @isInline={{true}} />
            <button
              type="button"
              class="consul-kv-list__name"
              data-test-kv={{row.node.Key}}
              data-test-name
              {{on "click" (fn this.toggle row.node)}}
            >{{row.name}}</button>
          {{else}}
            <span class="consul-kv-list__toggle-spacer" aria-hidden="true"></span>
            <Hds::Icon class="consul-kv-list__icon" @name="key" @size="16" @isInline={{true}} />
            <button
              type="button"
              class="consul-kv-list__name"
              data-test-kv={{row.node.Key}}
              data-test-name
              {{on "click" (fn @onSelect row.node.Key)}}
            >{{row.name}}</button>
          {{/if}}
        </span>
      </B.Td>

      {{! ---- Actions ---- }}
      <B.Td @align="right">
        <Hds::Dropdown @listPosition="bottom-right" class="consul-kv-list__actions" as |dd|>
          <dd.ToggleIcon
            @icon="more-horizontal"
            @text="Open actions menu"
            @hasChevron={{false}}
            @size="small"
            data-test-actions-menu
          />
          {{#if (can "write kv" item=row.node)}}
            {{#if row.isFolder}}
              <dd.Interactive
                data-test-edit
                {{on "click" (fn this.toggle row.node)}}
              >View</dd.Interactive>
            {{else}}
              <dd.Interactive
                data-test-edit
                {{on "click" (fn @onSelect row.node.Key)}}
              >Edit</dd.Interactive>
            {{/if}}
            {{#if row.isFolder}}
              {{#if (can "create kvs")}}
                <dd.Interactive
                  data-test-create-in-folder
                  {{on "click" (fn @onCreate row.node.Key)}}
                >Create</dd.Interactive>
              {{/if}}
            {{/if}}
            <dd.Separator />
            <dd.Interactive
              @color="critical"
              @icon="trash"
              data-test-delete
              {{on "click" (fn this.confirmDelete row.node)}}
            >Delete</dd.Interactive>
          {{else}}
            {{#if row.isFolder}}
              <dd.Interactive
                data-test-edit
                {{on "click" (fn this.toggle row.node)}}
              >View</dd.Interactive>
            {{else}}
              <dd.Interactive
                data-test-edit
                {{on "click" (fn @onSelect row.node.Key)}}
              >View</dd.Interactive>
            {{/if}}
          {{/if}}
        </Hds::Dropdown>
      </B.Td>
    </:row>
  </Consul::DataTable>

  {{! Live subscription for each expanded folder's children. Rendering these
      outside the table keeps the DOM valid (no nested <tr>) while the loaded
      children are spliced into the visible rows by the component. }}
  {{#each this.expandedFolders as |key|}}
    <DataSource
      @src={{uri '/${partition}/${nspace}/${dc}/kvs/${key}'
        (hash
          partition=@partition
          nspace=@nspace
          dc=@dc
          key=key
        )
      }}
      @onchange={{fn this.setChildren key}}
    />
  {{/each}}

  {{#if this.itemToDelete}}
    <Hds::Modal id="confirm-modal" @color="warning" @onClose={{this.cancelDelete}} as |M|>
      <M.Header @icon="alert-triangle">Confirm Delete</M.Header>
      <M.Body>
        <p>Are you sure you want to delete this KV entry?</p>
      </M.Body>
      <M.Footer as |F|>
        <Hds::ButtonSet>
          <Hds::Button @text="Delete" @color="critical" data-test-id="confirm-action" {{on "click" this.invokeDelete}} />
          <Hds::Button @text="Cancel" @color="secondary" {{on "click" F.close}} />
        </Hds::ButtonSet>
      </M.Footer>
    </Hds::Modal>
  {{/if}}
</div>
