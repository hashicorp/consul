<div class="consul-token-list" ...attributes>
  <Consul::DataTable
    @items={{@items}}
    @columns={{this.columns}}
    @ariaLabel="Tokens"
  >
    <:row as |item B|>
      {{! ---- Name ---- }}
      <B.Td>
        <span class="consul-token-list__name">
          {{#if (eq item.AccessorID @token.AccessorID)}}
            <span
              class="consul-token-list__me"
              {{hds-tooltip "Your token" options=(detached-tooltip-options placement="top-start")}}
            ></span>
          {{/if}}
          <a
            data-test-token={{item.AccessorID}}
            data-test-name
            href={{href-to 'dc.acls.tokens.edit' item.AccessorID}}
          >
            {{#if item.Name}}{{truncate item.Name 100}}{{else}}{{substr item.AccessorID -8}}{{/if}}
          </a>
          <Consul::Token::Ruleset::List @item={{item}} />
        </span>
      </B.Td>

      {{! ---- Scope ---- }}
      <B.Td>{{if item.Local 'local' 'global'}}</B.Td>

      {{! ---- Description ---- }}
      <B.Td>
        <em class="consul-token-list__description" data-test-description>
          {{item.Description}}
        </em>
      </B.Td>

      {{! ---- Secret ---- }}
      <B.Td>
        {{#if item.hasSecretID}}
          <ConsulCopyButton @value={{item.SecretID}} @name={{t 'components.consul.token.secretID'}}>
            {{t 'components.consul.token.secretID'}}
          </ConsulCopyButton>
        {{/if}}
      </B.Td>

      {{! ---- Actions ---- }}
      <B.Td @align="right">
        <Hds::Dropdown @listPosition="bottom-right" class="consul-token-list__actions" as |dd|>
          <dd.ToggleIcon
            @icon="more-horizontal"
            @text="Open actions menu"
            @hasChevron={{false}}
            @size="small"
            data-test-actions-menu
          />
          <dd.Interactive @route='dc.acls.tokens.edit' @model={{item.AccessorID}} data-test-edit>
            {{#if (can 'write token' item=item)}}Edit{{else}}View{{/if}}
          </dd.Interactive>
          {{#if (can 'duplicate token' item=item)}}
            <dd.Interactive data-test-clone {{on 'click' (fn @onclone item)}}>Duplicate</dd.Interactive>
          {{/if}}
          {{#if (eq item.AccessorID @token.AccessorID)}}
            <dd.Interactive @color="critical" data-test-logout {{on 'click' (fn this.confirm 'logout' item)}}>Logout</dd.Interactive>
          {{else}}
            <dd.Interactive data-test-use {{on 'click' (fn this.confirm 'use' item)}}>Use</dd.Interactive>
          {{/if}}
          {{#if (can 'delete token' item=item token=@token)}}
            <dd.Separator />
            <dd.Interactive @color="critical" @icon="trash" data-test-delete {{on 'click' (fn this.confirm 'delete' item)}}>Delete</dd.Interactive>
          {{/if}}
        </Hds::Dropdown>
      </B.Td>
    </:row>
  </Consul::DataTable>

  {{#if this.itemToConfirm}}
    <Hds::Modal id="confirm-modal" @color="warning" @onClose={{this.cancelConfirm}} as |M|>
      <M.Header @icon="alert-triangle">
        {{#if (eq this.confirmType 'use')}}Confirm use{{else if (eq this.confirmType 'logout')}}Confirm logout{{else}}Confirm delete{{/if}}
      </M.Header>
      <M.Body>
        {{#if (eq this.confirmType 'use')}}
          <p>Are you sure you want to use this ACL token?</p>
        {{else if (eq this.confirmType 'logout')}}
          <p>Are you sure you want to stop using this ACL token? This will log you out.</p>
        {{else}}
          <p>Are you sure you want to delete this token?</p>
        {{/if}}
      </M.Body>
      <M.Footer as |F|>
        <Hds::ButtonSet>
          <Hds::Button
            @text={{if (eq this.confirmType 'use') 'Use' (if (eq this.confirmType 'logout') 'Logout' 'Delete')}}
            @color={{if (eq this.confirmType 'delete') 'critical' 'primary'}}
            data-test-id="confirm-action"
            {{on 'click' this.invokeConfirm}}
          />
          <Hds::Button @text="Cancel" @color="secondary" {{on 'click' F.close}} />
        </Hds::ButtonSet>
      </M.Footer>
    </Hds::Modal>
  {{/if}}
</div>