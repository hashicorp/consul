<ListCollection
  class="consul-role-list"
  ...attributes
  @items={{@items}}>
    <:header as |item|>
      <a data-test-role={{item.Name}} href={{href-to 'dc.acls.roles.edit' item.ID}}>{{item.Name}}</a>
    </:header>
    <:details as |item|>
      <Consul::Token::Ruleset::List @item={{item}} />
      <dl>
        <dt>Description</dt>
        <dd data-test-description>
            {{item.Description}}
        </dd>
      </dl>
    </:details>
    <:actions as |item index Actions|>
      <Actions as |Action|>
        <Action data-test-edit-action @href={{href-to 'dc.acls.roles.edit' item.ID}}>
          <:label>
{{#if (can "write role" item=item)}}
            Edit
{{else}}
            View
{{/if}}
          </:label>
        </Action>
{{#if (can "delete role" item=item)}}
        <Action data-test-delete-action @onclick={{action @ondelete item}} class="dangerous">
          <:label>
            Delete
          </:label>
          <:confirmHeader>
            Confirm delete
          </:confirmHeader>
          <:confirmBody>
            <p>
              Are you sure you want to delete this role?
            </p>
          </:confirmBody>
          <:confirmFooter as |Params|>
            <Params.button @text='Delete' {{on 'click' Params.confirmAction}} />
          </:confirmFooter>
        </Action>
{{/if}}
      </Actions>
    </:actions>
</ListCollection>