<div class="consul-role-list" ...attributes>
  <Consul::DataTable
    @items={{@items}}
    @columns={{this.columns}}
    @ariaLabel="Roles"
  >
    <:row as |item B|>
      {{! ---- Role name ---- }}
      <B.Td>
        <span class="consul-role-list__name">
          <a
            data-test-role={{item.Name}}
            data-test-name
            href={{href-to 'dc.acls.roles.edit' item.ID}}
          >{{item.Name}}</a>
          <Consul::Token::Ruleset::List @item={{item}} />
        </span>
      </B.Td>

      {{! ---- Description ---- }}
      <B.Td>
        <em class="consul-role-list__description" data-test-description>
          {{item.Description}}
        </em>
      </B.Td>

      {{! ---- Actions ---- }}
      <B.Td @align="right">
        <Hds::Dropdown @listPosition="bottom-right" class="consul-role-list__actions" as |dd|>
          <dd.ToggleIcon
            @icon="more-horizontal"
            @text="Open actions menu"
            @hasChevron={{false}}
            @size="small"
            data-test-actions-menu
          />
          <dd.Interactive @route='dc.acls.roles.edit' @model={{item.ID}} data-test-edit>
            {{#if (can 'write role' item=item)}}Edit{{else}}View{{/if}}
          </dd.Interactive>
          {{#if (can 'delete role' item=item)}}
            <dd.Separator />
            <dd.Interactive @color="critical" @icon="trash" data-test-delete {{on 'click' (fn this.confirmDelete item)}}>Delete</dd.Interactive>
          {{/if}}
        </Hds::Dropdown>
      </B.Td>
    </:row>
  </Consul::DataTable>

  {{#if this.itemToDelete}}
    <Hds::Modal id="confirm-modal" @color="warning" @onClose={{this.cancelDelete}} as |M|>
      <M.Header @icon="alert-triangle">Confirm delete</M.Header>
      <M.Body>
        <p>Are you sure you want to delete this role?</p>
      </M.Body>
      <M.Footer as |F|>
        <Hds::ButtonSet>
          <Hds::Button @text="Delete" @color="critical" data-test-id="confirm-action" {{on 'click' this.invokeDelete}} />
          <Hds::Button @text="Cancel" @color="secondary" {{on 'click' F.close}} />
        </Hds::ButtonSet>
      </M.Footer>
    </Hds::Modal>
  {{/if}}
</div>