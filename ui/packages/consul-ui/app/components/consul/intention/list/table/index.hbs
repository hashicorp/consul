<div class="consul-intention-list-table" ...attributes>
  <Consul::DataTable
    @items={{@items}}
    @columns={{this.columns}}
    @initialSortBy="action"
    @ariaLabel="Intentions"
  >
    <:row as |item B|>
      <B.Td>
        <span class="consul-intention-list-table__name" data-test-intention={{item.ID}}>
          <a
            href={{href-to (or @routeName 'dc.intentions.edit') item.ID}}
            data-test-intention-source={{item.SourceName}}
          >
            {{#if (eq item.SourceName '*')}}All Services (*){{else}}{{item.SourceName}}{{/if}}
          </a>
        </span>
        <em class="consul-intention-list-table__meta-info">
          <Consul::Bucket::List
            @item={{hash
              Namespace=item.SourceNS
              Partition=item.SourcePartition
              PeerName=item.SourcePeer
            }}
            @nspace="-"
            @partition="-"
          />
        </em>
      </B.Td>
      <B.Td data-test-intention-action={{item.Action}}>
        <Consul::Intention::Action @action={{item.Action}} @label={{capitalize (or item.Action 'App aware')}} />
      </B.Td>
      <B.Td>
        <span class="consul-intention-list-table__name" data-test-intention-destination={{item.DestinationName}}>
          {{#if (eq item.DestinationName '*')}}All Services (*){{else}}{{item.DestinationName}}{{/if}}
        </span>
        {{#if (or (can 'use nspaces') (can 'use partitions'))}}
          <em class="consul-intention-list-table__meta-info">
            <span class={{concat 'partition-' (or item.DestinationPartition 'default')}}>{{or item.DestinationPartition 'default'}}</span>
            /
            <span class={{concat 'nspace-' (or item.DestinationNS 'default')}}>{{or item.DestinationNS 'default'}}</span>
          </em>
        {{/if}}
      </B.Td>
      <B.Td>
        {{#if (gt item.Permissions.length 0)}}
          <span>{{pluralize item.Permissions.length 'Permission'}}</span>
        {{/if}}
      </B.Td>
      <B.Td>
        {{#if item.IsManagedByCRD}}
          <span {{hds-tooltip "This intention is being managed through an Intention Custom Resource in your Kubernetes cluster. It is view only in the UI."}}>
            <Consul::ExternalSource @item={{item}} @label='Managed by CRD' />
          </span>
        {{/if}}
      </B.Td>
      <B.Td @align="right">
        <Hds::Dropdown @listPosition="bottom-right" class="consul-intention-list-table__actions" as |dd|>
          <dd.ToggleIcon
            @icon="more-horizontal"
            @text="Open actions menu"
            @hasChevron={{false}}
            @size="small"
            data-test-actions-menu
          />
          {{#if (can 'write intention' item=item)}}
            <dd.Interactive @route={{or @routeName 'dc.intentions.edit'}} @model={{item.ID}}>
              Edit
            </dd.Interactive>
            <dd.Separator />
            <dd.Interactive @color="critical" @icon="trash" data-test-delete {{on 'click' (fn this.confirmDelete item)}}>
              Delete
            </dd.Interactive>
          {{else}}
            <dd.Interactive @route={{or @routeName 'dc.intentions.edit'}} @model={{item.ID}}>
              View
            </dd.Interactive>
          {{/if}}
        </Hds::Dropdown>
      </B.Td>
    </:row>
  </Consul::DataTable>

  {{#if this.itemToDelete}}
    <Hds::Modal id="confirm-modal" @color="warning" @onClose={{this.cancelDelete}} as |M|>
      <M.Header @icon="alert-triangle">
        Confirm Delete
      </M.Header>
      <M.Body>
        <p>Are you sure you want to delete this intention?</p>
      </M.Body>
      <M.Footer as |F|>
        <Hds::ButtonSet>
          <Hds::Button @text="Delete" @color="critical" data-test-id="confirm-action" {{on 'click' this.invokeDelete}} />
          <Hds::Button @text="Cancel" @color="secondary" {{on 'click' F.close}} />
        </Hds::ButtonSet>
      </M.Footer>
    </Hds::Modal>
  {{/if}}
</div>
