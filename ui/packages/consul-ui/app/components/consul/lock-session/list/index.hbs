<ListCollection
  class="consul-lock-session-list"
  ...attributes
  @items={{@items}}>
  <:header as |item index|>
  {{#if item.Name}}
    <span>{{item.Name}}</span>
  {{else}}
    <span>
      {{item.ID}}
      <ConsulCopyButton
        @value={{item.ID}}
        @name="ID"
      />
    </span>
  {{/if}}
  </:header>
  <:details as |item index|>
    {{#if item.Name}}
    <dl>
      <dt>
        ID
      </dt>
      <dd>
        <ConsulCopyButton
          @value={{item.ID}}
          @name="ID"
        />
        {{item.ID}}
      </dd>
    </dl>
    {{/if}}
    <dl class="lock-delay">
      <dt {{hds-tooltip options=(detached-tooltip-options)}}>
        Delay
      </dt>
      <dd data-test-session-delay>{{duration-from item.LockDelay}}</dd>
    </dl>
    <dl class="ttl">
      <dt
        {{hds-tooltip options=(detached-tooltip-options)}}
      >
        TTL
      </dt>
    {{#if (eq item.TTL "")}}
      <dd data-test-session-ttl={{item.TTL}}>-</dd>
    {{else}}
      <dd data-test-session-ttl={{item.TTL}}>{{item.TTL}}</dd>
    {{/if}}
    </dl>
    <dl class="behavior">
      <dt
        {{hds-tooltip options=(detached-tooltip-options)}}
      >
        Behavior
      </dt>
      <dd>{{item.Behavior}}</dd>
    </dl>
{{#let (union item.NodeChecks item.ServiceChecks) as |checks|}}
    <dl class="checks">
      <dt
        {{hds-tooltip options=(detached-tooltip-options)}}
      >
        Checks
      </dt>
      <dd>
{{#if (gt checks.length 0)}}
      {{#each checks as |item|}}
        <span>{{item}}</span>
      {{/each}}
{{else}}
        -
{{/if}}
      </dd>
    </dl>
{{/let}}
  </:details>
  <:actions as |item index|>
    <ConfirmationDialog
      @message="Are you sure you want to invalidate this session?"
    >
      <:action as |confirm|>
        <Hds::Button
          @text='Invalidate'
          @color='critical'
          data-test-delete
          {{on 'click' confirm}}
        />
      </:action>
      <:dialog as |execute cancel message|>
        <p>
          {{message}}
        </p>
        <Hds::ButtonSet>
          <Hds::Button
            @text='Confirm Invalidate'
            @color='critical'
            data-test-delete
            {{on 'click' (queue execute (fn @ondelete item))}}
          />
          <Hds::Button
            @text='Cancel'
            @color='secondary'
            {{on 'click' cancel}}
          />
        </Hds::ButtonSet>
      </:dialog>
    </ConfirmationDialog>
  </:actions>
</ListCollection>