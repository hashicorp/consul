<span class="consul-acl-ruleset-badge" data-type={{this.type}} aria-label={{this.ariaLabel}} ...attributes>
  {{#if this.hasIcon}}
    <Hds::Badge
      @text={{this.label}}
      @icon={{this.icon}}
      @color="neutral"
      @type="filled"
      @size="small"
    />
  {{else}}
    <Hds::Badge
      @text={{this.label}}
      @color="neutral"
      @type="filled"
      @size="small"
    />
  {{/if}}
</span>
