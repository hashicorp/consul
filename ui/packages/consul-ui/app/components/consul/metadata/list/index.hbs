<TabularCollection
  data-test-metadata
  class="consul-metadata-list"
  @items={{@items}}
>
    <:header>
        <th>Key</th>
        <th>Value</th>
    </:header>
    <:row as |item index|>
        <td>
          <span>
            {{object-at 0 item}}
          </span>
        </td>
        <td>
          <span>{{object-at 1 item}}</span>
        </td>
    </:row>
</TabularCollection>
