{{#let (icon-mapping @item.Type) as |flightIcon|}}
  <span class="consul-auth-method-type--hds" data-test-type={{@item.Type}}>
    {{#if flightIcon}}
      <Hds::Icon @name={{flightIcon}} class="mr-1.5 w-4 h-4" />
    {{/if}}
    <Hds::Badge
      @text={{t (concat "common.brand." @item.Type)}}
      @color="neutral"
      @type="filled"
      @size="small"
    />
  </span>
{{/let}}
