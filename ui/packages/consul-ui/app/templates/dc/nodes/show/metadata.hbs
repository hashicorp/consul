<Route
  @name={{this.routeName}}
as |route|>
  <div class="tab-section">
  {{#if route.model.item.Meta}}
    <Consul::Metadata::List @items={{entries route.model.item.Meta}} />
  {{else}}
    <EmptyState>
      <:body>
        <p>
          This node has no metadata.
        </p>
      </:body>
    </EmptyState>
  {{/if}}
  </div>
</Route>
