<Route
  @name={{this.routeName}}
as |route|>
{{#let
  route.model.item
as |item|}}
  <div class="tab-section">
      <section class="tags">
        <h2>Tags</h2>
      {{#if (gt item.Tags.length 0) }}
        <TagList @item={{item}} />
      {{else}}
        <EmptyState>
          <:body>
            <p>
              There are no tags.
            </p>
          </:body>
        </EmptyState>
      {{/if}}
      </section>
      <section class="metadata">
        <h2>Meta</h2>
      {{#if item.Meta}}
        <Consul::Metadata::List @items={{entries item.Meta}} />
      {{else}}
        <EmptyState>
          <:body>
            <p>
              This instance has no metadata.
            </p>
          </:body>
        </EmptyState>
      {{/if}}
      </section>
  </div>
{{/let}}
</Route>
