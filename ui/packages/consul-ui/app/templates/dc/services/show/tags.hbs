<Route
  @name={{this.routeName}}
as |route|>
  <div class="tab-section">
  {{#let (flatten (map-by "Tags" route.model.items)) as |tags|}}
    {{#if (gt tags.length 0) }}
        <TagList @item={{hash Tags=tags}} />
    {{else}}
        <EmptyState>
          <:header>
            <h2>
              {{t 'routes.dc.services.show.tags.empty.header'}}
            </h2>
          </:header>
          <:body>
            {{t 'routes.dc.services.show.tags.empty.body'
              htmlSafe=true
            }}
          </:body>
        </EmptyState>
    {{/if}}
  {{/let}}
  </div>
</Route>
