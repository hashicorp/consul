<Route
  @name={{this.routeName}}
as |route|>
{{! The Consul::Kv::Flyout (open via the kv/creating query params) sets its own }}
{{! title while it's open -- suppress this one then so they don't both stack, }}
{{! since unlike a route transition, the list here never actually unmounts. }}
{{#unless (or this.kv this.creating)}}
{{#if (eq (or route.params.key '/') '/')}}
  {{page-title "Key / Value"}}
{{else}}
  {{page-title (take 1 (drop 1 (reverse (split (or route.params.key '/') '/'))))}}
{{/if}}
{{/unless}}
  <DataSource
    @src={{uri '/${partition}/${nspace}/${dc}/kv/${key}'
      (hash
        partition=route.params.partition
        nspace=route.params.nspace
        dc=route.params.dc
        key=(or route.params.key '/')
      )
    }}
    @onchange={{action (mut this.parent) value="data"}}
  />
  <DataLoader
    @src={{uri '/${partition}/${nspace}/${dc}/kvs/${key}'
      (hash
        partition=route.params.partition
        nspace=route.params.nspace
        dc=route.params.dc
        key=(or route.params.key '/')
      )}}>

    <:error as |loader|>
      <AppError
        @error={{loader.error}}
        @login={{route.model.app.login.open}}
      />
    </:error>
      <:disconnected as |loader after|>
        {{#if (eq loader.error.status "404")}}
          <Hds::Toast
            @color='warning'
            {{notification sticky=true}}
            as |T|>
            <T.Title>Warning!</T.Title>
            <T.Description>
              This KV or parent of this KV was deleted.
            </T.Description>
          </Hds::Toast>
        {{else if (eq loader.error.status "403")}}
          <Hds::Toast
            @color='critical'
            {{notification sticky=true}}
            as |T|>
            <T.Title>Error!</T.Title>
            <T.Description>
              You no longer have access to this KV.
            </T.Description>
          </Hds::Toast>
        {{else}}
          <Hds::Toast
            @color='warning'
            {{notification sticky=true}}
            as |T|>
            <T.Title>Warning!</T.Title>
            <T.Description>
              An error was returned whilst loading this data, refresh to try again.
            </T.Description>
          </Hds::Toast>
        {{/if}}
      </:disconnected>

    <:loaded as |loader|>
{{#let

  (hash
    value=(or this.sortBy "Kind:asc")
    change=(action (mut this.sortBy) value="target.selected")
  )

  (hash
    kind=(hash
      value=(if this.kind (split this.kind ',') undefined)
      change=(action (mut this.kind) value="target.selectedItems")
    )
  )

  this.parent
  loader.data

as |sort filters parent items|}}
    <Consul::Kv::Browser
      @dc={{route.params.dc}}
      @nspace={{route.params.nspace}}
      @partition={{route.params.partition}}
      @parent={{parent}}
      @items={{items}}
      @sort={{sort}}
      @filters={{filters}}
      @search={{this.search}}
      @onsearch={{action (mut this.search) value="target.value"}}
      @login={{route.model.app.login.open}}
      @onSelect={{mut this.kv}}
      @onCreate={{mut this.creating}}
    />

{{#if (or this.kv (and this.creating (can 'create kvs')))}}
{{#let
  (if this.creating
    this.creating
    (concat (join '/' (slice 0 -1 (split (or this.kv '') '/'))) '/')
  )
as |flyoutParent|}}
    {{! Re-fetch the list (not a route refresh -- that would race with the query }}
    {{! param reset below and re-add ?create/?kv) so a just created/edited key }}
    {{! shows immediately, since the blocking query won't re-poll on its own. }}
    <Consul::Kv::Flyout
      @isCreate={{if this.creating true false}}
      @selected={{this.kv}}
      @dc={{route.params.dc}}
      @nspace={{route.params.nspace}}
      @partition={{route.params.partition}}
      @parent={{flyoutParent}}
      @onsubmit={{queue (fn (mut this.kv) undefined) (fn (mut this.creating) undefined) loader.invalidate}}
    />
{{/let}}
{{/if}}
{{/let}}
    </:loaded>
  </DataLoader>
</Route>
