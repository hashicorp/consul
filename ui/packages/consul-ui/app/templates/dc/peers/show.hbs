<Route @name={{this.routeName}} as |route|>
  <DataLoader
    @src={{uri
      "/${partition}/${nspace}/${dc}/peer/${name}"
      (hash
        partition=route.params.partition
        nspace=route.params.nspace
        dc=route.params.dc
        name=route.params.name
      )
    }}
  >

    <:error as |loader|>
      <AppError @error={{loader.error}} @login={{route.model.app.login.open}} />
    </:error>

    <:loaded as |loader|>
      {{#let
        route.params.dc
        route.params.partition
        route.params.nspace
        loader.data
        as |dc partition nspace item|
      }}
        <AppView>
          <:breadcrumbs>
            <Hds::Breadcrumb>
              <Hds::Breadcrumb::Item @text="All Peers" @route="dc.peers" @model={{route.params.dc}} data-test-back />
            </Hds::Breadcrumb>
          </:breadcrumbs>
          <:header>
            <h1>
              <route.Title @title={{item.Name}} />
            </h1>
          </:header>
          <:content>
            <Consul::Peer::BentoBox @peering={{item}} />
            <Peerings::Provider @peer={{item}} as |peering|>
              <TabNav @items={{peering.data.tabs}} />

            </Peerings::Provider>
            <Outlet
              @name={{this.routeName}}
              @model={{assign
                (hash items=item.PeerServerAddresses peer=item)
                route.model
              }}
              as |o|
            >
              {{outlet}}
            </Outlet>
          </:content>
        </AppView>
      {{/let}}
    </:loaded>
  </DataLoader>
</Route>